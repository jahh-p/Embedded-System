#include <xc.h>

#pragma config FOSC = XT 
#pragma config WDTE = OFF 
#pragma config PWRTE = ON 
#pragma config BOREN = ON 
#pragma config LVP = OFF 
#pragma config CPD = OFF 
#pragma config WRT = OFF 
#pragma config CP = OFF 

// Map the 74C922 hex outputs (0-15) to real BCD numbers (0-9).
// Keys A, B, C, D, *, and # are forced to output 0.
const unsigned char keyMap[16] = {
    1, 2, 3, 0, // 0x00-0x03 (Keys: '1', '2', '3', 'A')
    4, 5, 6, 0, // 0x04-0x07 (Keys: '4', '5', '6', 'B')
    7, 8, 9, 0, // 0x08-0x0B (Keys: '7', '8', '9', 'C')
    0, 0, 0, 0  // 0x0C-0x0F (Keys: '*', '0', '#', 'D') -> Key '0' is at 0x0D
};

// Global variables (v1.33 compatible)
unsigned char update_display = 0;
unsigned char current_key = 0;

// Interrupt Service Routine
void interrupt ISR(void) {
    
    // Check if the Keypad triggered the External Interrupt on RB0
    if (INTF == 1) {
        INTF = 0; // Clear the hardware flag
        
        // Read the lower 4 bits of PORTD (Keypad Data A, B, C, D)
        current_key = PORTD & 0x0F; 
        
        // Tell the main loop to update the display
        update_display = 1; 
    }
}

void main(void) {
    // 1. Port Configuration
    TRISB = 0xFF; // Set RB0 as input for the interrupt (DAVBL from keypad)
    TRISC = 0x00; // Set RC0-RC3 as output for the 7-segment decoder
    TRISD = 0xFF; // Set RD0-RD3 as input for the keypad data
    
    // "Initially display 0" per your instructions
    PORTC = 0x00; 

    // 2. Interrupt Configuration
    // Set OPTION_REG to trigger the interrupt on a Rising Edge (Low to High)
    OPTION_REG = 0xC0; 

    INTF = 0; // Clear External Interrupt Flag
    INTE = 1; // Enable External Interrupt (RB0)
    GIE = 1;  // Enable Global Interrupts

    // 3. Main Loop
    while(1) {
        // If the ISR flagged that a new key was pressed...
        if (update_display == 1) {
            update_display = 0; // Reset software flag
            
            // Map the raw keypad data to 0-9 and send it to the 7-segment decoder
            PORTC = keyMap[current_key]; 
        }
    }
}